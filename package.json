{
  "name": "mohit-tiwari-academic",
  "version": "1.0.0",
  "private": true,
  "description": "Academic research portal for Mohit Tiwari, Assistant Professor at BVCOE New Delhi.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "sync-orcid": "node scripts/sync/orcid.mjs",
    "sync-github": "node scripts/sync/github.mjs",
    "sync-all": "node scripts/sync/all.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:research": "node scripts/validate-research.mjs",
    "lint": "eslint .",
