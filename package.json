    "check": "npm run validate:content && npm run validate:research && npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
